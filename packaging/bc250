#!/usr/bin/env bash
# Multicall entry point for the package's stable bc250-* command names.
set -Eeuo pipefail

LIBEXEC="${BC250_LIBEXEC:-/usr/libexec/bc250-llm-server}"
SHARE="${BC250_SHARE:-/usr/share/bc250-llm-server}"
DOCDIR="${BC250_DOCDIR:-/usr/share/doc/bc250-llm-server}"

# One table drives both installed aliases and command dispatch. Fields after
# the command name form the executable argv prefix.
ROUTES=(
  "40cu|$LIBEXEC/40cu.sh"
  "benchmark|$LIBEXEC/compare-models.sh"
  "check-temp|$LIBEXEC/check-temp.sh"
  "code|$LIBEXEC/coding-agent/coding-agent.sh"
  "code-commit|$LIBEXEC/coding-agent/commit-agent.sh"
  "compare-experiments|$LIBEXEC/compare-experiments.sh"
  "cu-status|$LIBEXEC/cu-status.sh"
  "fetch-experiments|$LIBEXEC/modelctl|install|experiments"
  "fetch-models|$LIBEXEC/modelctl|install|production"
  "fetch-mtp|$LIBEXEC/modelctl|install|mtp"
  "gitea-review|$LIBEXEC/coding-agent/gitea-review.sh"
  "install-cu-manager|$LIBEXEC/install-cu-manager.sh"
  "install-ollama|$LIBEXEC/install-ollama.sh"
  "memory-profile|$LIBEXEC/memory-profile.sh"
  "model|$LIBEXEC/modelctl"
  "ollama-profile|$LIBEXEC/ollama-profile.sh"
  "pull-embedding-model|$LIBEXEC/pull-embedding-model.sh"
  "run-mtp|$LIBEXEC/run-mtp-llamacpp.sh"
  "setup-coding-agent|$SHARE/examples/coding-agent/setup-ollama.sh"
  "setup-task-model|$SHARE/examples/task-model/setup-ollama.sh"
  "swap-profile|$LIBEXEC/swap-profile.sh"
  "uninstall|$LIBEXEC/uninstall.sh"
  "uninstall-info|cat|$DOCDIR/UNINSTALL.md"
  "verify|$LIBEXEC/verify.sh"
  "verify-lan|$LIBEXEC/verify-lan.sh"
)

if [[ "${1:-}" == --list-aliases ]]; then
  for route in "${ROUTES[@]}"; do printf '%s\n' "${route%%|*}"; done
  exit 0
fi

invoked="${0##*/}"
if [[ "$invoked" == bc250 ]]; then
  command="${1:-help}"
  (($# == 0)) || shift
else
  command="${invoked#bc250-}"
fi

usage() {
  cat <<'USAGE'
Usage: bc250 COMMAND [ARGUMENTS...]

Models:
  model, fetch-models, fetch-experiments, fetch-mtp
  setup-task-model, setup-coding-agent, pull-embedding-model

Operation:
  verify, verify-lan, benchmark, check-temp
  install-ollama, ollama-profile, memory-profile, swap-profile
  40cu, cu-status, install-cu-manager, uninstall

Optional workflows:
  code, code-commit, gitea-review, compare-experiments, run-mtp

Run `bc250 COMMAND --help` where supported. The bc250-COMMAND compatibility
names are symlinks to this dispatcher.
USAGE
}

case "$command" in
  help|-h|--help) usage; exit 0 ;;
esac

for route in "${ROUTES[@]}"; do
  IFS='|' read -r -a fields <<< "$route"
  [[ "${fields[0]}" == "$command" ]] || continue
  exec "${fields[@]:1}" "$@"
done

echo "ERROR: unknown command: $command" >&2
usage >&2
exit 2
