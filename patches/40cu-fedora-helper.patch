diff --git a/scripts/bc250-enable-40cu-fedora.sh b/scripts/bc250-enable-40cu-fedora.sh
index a46ef18..832c08c 100755
--- a/scripts/bc250-enable-40cu-fedora.sh
+++ b/scripts/bc250-enable-40cu-fedora.sh
@@ -9,6 +9,6 @@
 #   sudo ./bc250-enable-40cu-fedora.sh restore   # restore original amdgpu module
 #
-# Requirements: kernel-devel, gcc, make, zstd, curl. Must run as root on BC-250.
+# Requirements: kernel-devel, gcc, make, xz, zstd, curl, dracut. Must run as root on BC-250.
 # Tested on: Fedora 43 with kernel 7.0.9-105.fc43.x86_64
 #
 # Authors: duggasco, Claude, Martin | License: GPL-2.0
@@ -97,12 +97,14 @@ check_deps() {
     command -v make >/dev/null 2>&1 || missing="${missing} make"
     command -v zstd >/dev/null 2>&1 || missing="${missing} zstd"
+    command -v xz >/dev/null 2>&1 || missing="${missing} xz"
     command -v curl >/dev/null 2>&1 || missing="${missing} curl"
+    command -v dracut >/dev/null 2>&1 || missing="${missing} dracut"
     if [ ! -d "${MODDIR}/build" ]; then
         missing="${missing} linux-headers"
     fi
     if [ -n "$missing" ]; then
         err "Missing dependencies:${missing}"
-        err "Install with: dnf install kernel-devel-$(uname -r) gcc make zstd curl"
+        err "Install with: dnf install kernel-devel-$(uname -r) gcc make xz zstd curl dracut"
         exit 1
     fi
 }
@@ -253,25 +255,63 @@ build_module() {
+module_target() {
+    local resolved=""
+    resolved="$(modinfo -n amdgpu 2>/dev/null || true)"
+    case "$resolved" in
+        "$MODPATH"|"${MODPATH}.xz"|"${MODPATH}.zst")
+            printf '%s\n' "$resolved"
+            return 0
+            ;;
+    esac
+    local candidate
+    for candidate in "${MODPATH}.xz" "${MODPATH}.zst" "$MODPATH"; do
+        if [ -f "$candidate" ]; then
+            printf '%s\n' "$candidate"
+            return 0
+        fi
+    done
+    printf '%s\n' "${MODPATH}.zst"
+}
+
+refresh_module_state() {
+    depmod -a "$KVER"
+    dracut --force --kver "$KVER"
+}
+
 install_module() {
     local built="$1"
-    local target="${MODPATH}"
-
-    if [ -f "${target}.zst" ]; then
-        target="${target}.zst"
-    elif [ ! -f "$target" ]; then
-        target="${target}.zst"
-    fi
+    local target
+    target="$(module_target)"
 
     if [ -f "$target" ] && [ ! -f "${target}${BACKUP_SUFFIX}" ]; then
         info "Backing up original to ${target}${BACKUP_SUFFIX}"
-        cp "$target" "${target}${BACKUP_SUFFIX}"
+        cp --preserve=mode,timestamps "$target" "${target}${BACKUP_SUFFIX}"
     fi
 
-    if [ "${target%.zst}" != "$target" ]; then
-        info "Compressing and installing module..."
-        zstd -f "$built" -o "$target"
-    else
-        cp "$built" "$target"
-    fi
+    local staged="${target}.bc250-new"
+    rm -f "$staged"
+    case "$target" in
+        *.xz)
+            info "Compressing and installing XZ module..."
+            xz --compress --stdout "$built" > "$staged"
+            ;;
+        *.zst)
+            info "Compressing and installing Zstandard module..."
+            zstd --force --quiet "$built" -o "$staged"
+            ;;
+        *) cp "$built" "$staged" ;;
+    esac
+    chmod --reference="${target}${BACKUP_SUFFIX}" "$staged" 2>/dev/null || chmod 0644 "$staged"
+    mv -f "$staged" "$target"
+
+    local alternate
+    for alternate in "${MODPATH}.xz" "${MODPATH}.zst" "$MODPATH"; do
+        [ "$alternate" = "$target" ] && continue
+        [ -f "$alternate" ] || continue
+        if modinfo "$alternate" 2>/dev/null | grep -q 'bc250_cc_write_mode'; then
+            warn "Removing stale patched duplicate module: ${alternate}"
+            rm -f "$alternate"
+        fi
+    done
 
-    depmod -a "$KVER"
+    refresh_module_state
     info "Module installed at ${target}"
 }
@@ -293,10 +333,15 @@ do_enable() {
     printf '# BC-250 40 CU re-enablement\noptions amdgpu bc250_cc_write_mode=3\n' > "$CONF40"
     info "40 CU mode configured in ${CONF40}"
-    if ! ( set +o pipefail; modinfo amdgpu 2>/dev/null | grep -q 'bc250_cc_write_mode' ); then
+    local target
+    target="$(module_target)"
+    if ! ( set +o pipefail; modinfo "$target" 2>/dev/null | grep -q 'bc250_cc_write_mode' ); then
         warn "Patched module not detected. Run: sudo $0 build"
         rm -f "$CONF40"
         exit 1
     fi
+    info "Patched module detected at ${target}"
+    info "Refreshing initramfs for ${KVER}..."
+    refresh_module_state
     info "Rebooting..."
     sleep 2
     reboot
@@ -306,17 +351,19 @@ do_enable() {
     rm -f "$CONF40"
+    info "Refreshing initramfs for ${KVER}..."
+    refresh_module_state
     info "40 CU config removed. Rebooting to stock 24 CU..."
     sleep 2
     reboot
 }
 
 do_restore() {
-    local target="${MODPATH}"
-    if [ -f "${target}.zst" ]; then target="${target}.zst"; fi
+    local target
+    target="$(module_target)"
     local backup
-    backup="$(ls -1 "${target}.bc250-backup-"* 2>/dev/null | head -1)"
+    backup="$(ls -1t "${target}.bc250-backup-"* 2>/dev/null | head -1)"
     [ -n "$backup" ] || die "No backup found"
     cp "$backup" "$target"
     rm -f "$CONF40"
-    depmod -a "$KVER"
-    info "Original module restored. Reboot to apply."
+    refresh_module_state
+    info "Original module restored and initramfs refreshed. Reboot to apply."
 }
@@ -330,7 +377,9 @@ do_status() {
         printf '  PCI device:     \033[0;31mBC-250 not found\033[0m\n'
     fi
 
-    if ( set +o pipefail; modinfo amdgpu 2>/dev/null | grep -q 'bc250_cc_write_mode' ); then
+    local target
+    target="$(module_target)"
+    if ( set +o pipefail; modinfo "$target" 2>/dev/null | grep -q 'bc250_cc_write_mode' ); then
         printf '  amdgpu module:  \033[0;32mpatched\033[0m\n'
     else
         printf '  amdgpu module:  \033[0;33mstock (unpatched)\033[0m\n'
@@ -383,5 +432,5 @@ case "${1:-}" in
         echo "  sudo $0 build && sudo $0 enable"
         echo ""
-        echo "Dependencies: dnf install kernel-devel-$(uname -r) gcc make zstd curl"
+        echo "Dependencies: dnf install kernel-devel-$(uname -r) gcc make xz zstd curl dracut"
         ;;
 esac
