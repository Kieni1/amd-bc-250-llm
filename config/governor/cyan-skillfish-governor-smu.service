[Unit]
Description=Cyan Skillfish GPU Governor (SMU)
Conflicts=cyan-skillfish-governor.service cyan-skillfish-governor-tt.service oberon-governor.service

[Service]
ExecStart=/usr/bin/cyan-skillfish-governor-smu /etc/cyan-skillfish-governor-smu/config.toml
ManagedOOMPreference=avoid
OOMScoreAdjust=-1000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
