# Installed as /etc/bc250-llm-server/maintenance.env (root:root 0600).
OWUI_URL=http://127.0.0.1:3000
OWUI_API_KEY=REPLACE_WITH_ADMIN_API_KEY
MAX_AGE_DAYS=90
MAX_TOTAL_GB=100
DRY_RUN=1
WARMUP_MODEL=prod-qwen3-4b-lmstudio-q6-k
WARMUP_KEEP_ALIVE=3h
KEEP_CONFIG=7
KEEP_USERS=14
CFG_OUT_DIR=/var/backups/bc250-llm-server/config
USERS_OUT_DIR=/var/backups/bc250-llm-server/users
CFG_ROLLBACK_DIR=/var/backups/bc250-llm-server/rollback/config
USERS_ROLLBACK_DIR=/var/backups/bc250-llm-server/rollback/users
SAFE_SUSPEND_PORTS="22 80 443 3000 11434 11435 11436"
