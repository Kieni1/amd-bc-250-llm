# Ollama model: prod-gpt-oss20b-ggml-org-mxfp4
# Source: ggml-org/gpt-oss-20b-GGUF @ latest
# GGUF: gpt-oss-20b-MXFP4.gguf
FROM /var/lib/bc250-llm-server/gguf/production/gpt-oss-20b-MXFP4.gguf

# BC-250: Ollama once chose 13/25 GPU layers (22 vs 84 tok/s). Do not remove.
PARAMETER num_gpu 99
PARAMETER num_ctx 16384
# Preserve the SYSTEM prefix when old context is evicted.
PARAMETER num_keep 256
# GPT-OSS sampling.
PARAMETER temperature 1.0
PARAMETER top_p 1.0
PARAMETER top_k 0

SYSTEM """You are a local reasoning and drafting assistant. Give the answer directly, state assumptions and uncertainty, and answer in the user's language."""
