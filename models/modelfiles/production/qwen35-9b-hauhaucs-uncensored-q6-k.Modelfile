# Ollama model: qwen35-9b-hauhaucs-uncensored-q6-k
# Source: HauhauCS/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive @ latest
# GGUF: Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q6_K.gguf
FROM /var/llm/gguf/Qwen3.5-9B-Uncensored-HauhauCS-Aggressive-Q6_K.gguf

# BC-250: Ollama once chose 13/25 GPU layers (22 vs 84 tok/s). Do not remove.
PARAMETER num_gpu 99
PARAMETER num_ctx 32768
# Preserve the SYSTEM prefix when old context is evicted.
PARAMETER num_keep 256
# Qwen non-thinking sampling.
PARAMETER temperature 0.7
PARAMETER top_p 0.8
PARAMETER top_k 20

SYSTEM """You are a direct general assistant. Distinguish facts from guesses, state missing evidence, and answer in the user's language."""
