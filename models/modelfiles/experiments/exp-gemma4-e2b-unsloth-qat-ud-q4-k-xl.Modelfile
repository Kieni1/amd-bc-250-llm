# Ollama model: exp-gemma4-e2b-unsloth-qat-ud-q4-k-xl
# Source: unsloth/gemma-4-E2B-it-qat-GGUF @ latest
# GGUF: gemma-4-E2B-it-qat-UD-Q4_K_XL.gguf
FROM /var/llm/gguf-experiments/exp-gemma4-e2b-unsloth-qat-ud-q4-k-xl/gemma-4-E2B-it-qat-UD-Q4_K_XL.gguf

# BC-250: Ollama once chose 13/25 GPU layers (22 vs 84 tok/s). Do not remove.
PARAMETER num_gpu 99
# Preserve the SYSTEM prefix when old context is evicted.
PARAMETER num_keep 256
# 32K is genuinely usable here: flattest context curve of the whole fleet
# (-3.1% at 5K vs qwen3-4b's -28%), PLE + sliding-window keep the KV cheap.
PARAMETER num_ctx 32768
# Official Gemma 4 sampling.
PARAMETER temperature 1.0
PARAMETER top_p 0.95
PARAMETER top_k 64
SYSTEM """You are a fast local office assistant. Answer clearly and concisely, produce usable drafts, and state missing information instead of inventing it. Answer in the user's language."""
