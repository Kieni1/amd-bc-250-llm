# Ollama model: exp-gpt-oss20b-unsloth-q2-k-l
# Source: unsloth/gpt-oss-20b-GGUF @ latest
# GGUF: gpt-oss-20b-Q2_K_L.gguf
FROM /var/llm/gguf-experiments/gpt-oss-unsloth-q2-k-l-Q2_K_L/gpt-oss-20b-Q2_K_L.gguf

# BC-250: Ollama once chose 13/25 GPU layers (22 vs 84 tok/s). Do not remove.
PARAMETER num_gpu 99
# Preserve the SYSTEM prefix when old context is evicted.
PARAMETER num_keep 256
PARAMETER num_ctx 8192
PARAMETER temperature 1.0
PARAMETER top_p 1.0
PARAMETER top_k 0
SYSTEM """You are an experimental office reasoning assistant. Answer clearly and completely, and state uncertainty instead of guessing. Answer in the language used by the user."""
