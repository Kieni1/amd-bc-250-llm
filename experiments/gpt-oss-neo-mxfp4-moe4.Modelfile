# Ollama model: exp-gpt-oss20b-davidau-neo-mxfp4-moe4
# Source: DavidAU/Openai_gpt-oss-20b-NEO-GGUF @ latest
# GGUF: OpenAI-20B-NEO-MXFP4_MOE4.gguf
FROM /var/llm/gguf-experiments/gpt-oss-neo-mxfp4-moe4-MXFP4_MOE4/OpenAI-20B-NEO-MXFP4_MOE4.gguf

# BC-250: Ollama once chose 13/25 GPU layers (22 vs 84 tok/s). Do not remove.
PARAMETER num_gpu 99
# Preserve the SYSTEM prefix when old context is evicted.
PARAMETER num_keep 256
PARAMETER num_ctx 16384
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER min_p 0.05
PARAMETER repeat_penalty 1.1
PARAMETER repeat_last_n 256
SYSTEM """You are an experimental general and coding assistant. Follow the request accurately, keep the response proportionate to the task, and distinguish facts from assumptions. Answer in the user's language."""
